#include <Wire.h>
#include <LiquidCrystal_I2C.h>
LiquidCrystal_I2C lcd(0x27, 16, 2);

int voltageV = A0;  // input pin

void setup() {
lcd.init(); 
lcd.backlight();
pinMode (voltageV, INPUT);
pinMode(13, OUTPUT);
}

void loop() {
  digitalWrite(13, HIGH);                   //sets pin 13 as VCC
  int VoltageMsmt = analogRead(voltageV);
  float Vcalc = (4.6/1023)*VoltageMsmt;     //calculates voltage
  lcd.setCursor(0, 0);
  lcd.print("Batt ");
  lcd.print(Vcalc);                         //displays voltage calculation
}
